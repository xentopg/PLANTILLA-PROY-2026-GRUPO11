<!DOCTYPE html>
<html lang="es">
<head>
    <title>Xentlock Control</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <style>
        body { font-family: Arial, sans-serif; text-align: center; background-color: #f4f4f4; padding-top: 50px; }
        
        /* Se añade la tarjeta contenedora principal */
        .tarjeta { background-color: white; padding: 30px; border-radius: 20px; display: inline-block; box-shadow: 0px 4px 10px rgba(0, 0, 0, 0.1); width: 90%; max-width: 500px; }
        .btn { display: block; width: 100%; padding: 15px; margin-top: 15px; font-size: 1.1em; font-weight: bold; color: white; border: none; border-radius: 50px; cursor: pointer; }
        .tarjeta-usuario { background-color: #f8f9fa; border-left: 5px solid #3498db; padding: 15px; margin-top: 12px; border-radius: 8px; text-align: left; display: flex; justify-content: space-between; align-items: center; }
    </style>
</head>
<body>
    <div class="tarjeta">
        <h1>Xentlock</h1>
        <p>Estado del sistema:</p>
        <h2 id="txt-estado">{{ estado }}</h2>
        <hr>

        <button class="btn" style="background-color: #2ecc71;" onclick="enviarComando('abrir')">🔓 ABRIR CANDADO</button>
        <button class="btn" style="background-color: #e74c3c;" onclick="enviarComando('cerrar')">🔒 CERRAR CANDADO</button>

        <div style="margin-top: 40px;">
            <h3 style="text-align: left;">Usuarios Registrados</h3>
            {% for usuario in usuarios %}
            <div class="tarjeta-usuario">
                <div>
                    <strong>👤 {{ usuario.nombre }}</strong><br>
                    <small style="color: #7f8c8d;">{{ usuario.metodo }} - {{ usuario.id_sensor }}</small>
                </div>
                <button onclick="eliminarUsuario('{{ usuario.nombre }}')" style="background-color: #e74c3c; color: white; border: none; padding: 8px; border-radius: 6px; cursor: pointer;">❌</button>
            </div>
            {% endfor %}
        </div>

        <div style="margin-top: 30px; padding-top: 20px; border-top: 2px solid #ecf0f1;">
            <h3 style="text-align: left;">Registrar Nuevo Usuario</h3>
            <input type="text" id="input-nombre" placeholder="Ej: Lionel Messi" style="width: 100%; padding: 10px; border-radius: 8px; border: 1px solid #ccc; box-sizing: border-box;">
            <button onclick="registrarUsuario()" class="btn" style="background-color: #1e88e5;">➕ GUARDAR EN XENTLOCK</button>
        </div>
    </div>

    <script>
        function enviarComando(accion) {
            fetch('api/' + accion, {method: 'POST'})
                .then(response => response.json())
                .then(data => { document.getElementById('txt-estado').innerText = data.nuevo_estado; });
        }

        function registrarUsuario() {
            let nombreIngresado = document.getElementById('input-nombre').value;
            if (nombreIngresado.trim() === "") return alert("Por favor, escribe un nombre.");

            fetch('/api/agregar', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ nombre: nombreIngresado })
            })
            .then(response => response.json())
            .then(data => { if (data.status === "success") location.reload(); });
        }

        function eliminarUsuario(nombreUsuario) {
            if (!confirm("¿Estás seguro de que deseas eliminar a " + nombreUsuario + "?")) return;

            fetch('/api/eliminar', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ nombre: nombreUsuario })
            })
            .then(response => response.json())
            .then(data => { if (data.status === "success") location.reload(); });
        }
    </script>
</body>
</html>
